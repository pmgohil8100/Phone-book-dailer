<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Display area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <TextView
            android:id="@+id/tvDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:hint="Enter number"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"
            android:paddingStart="60dp"
            android:paddingEnd="60dp"
            android:singleLine="true"
            android:ellipsize="start" />

        <!-- Delete button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:paddingEnd="32dp"
            android:paddingTop="8dp">

            <ImageView
                android:id="@+id/btnBackspace"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_input_delete"
                android:tint="@color/text_secondary"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp" />

    <!-- Dial Pad -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="12dp">

        <!-- Row 1: 1 2 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button android:id="@+id/btn1" style="@style/DialerKey" android:text="1" android:tag="1"/>
            <Button android:id="@+id/btn2" style="@style/DialerKey" android:text="2" android:tag="2"/>
            <Button android:id="@+id/btn3" style="@style/DialerKey" android:text="3" android:tag="3"/>
        </LinearLayout>

        <!-- Row 2: 4 5 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button android:id="@+id/btn4" style="@style/DialerKey" android:text="4" android:tag="4"/>
            <Button android:id="@+id/btn5" style="@style/DialerKey" android:text="5" android:tag="5"/>
            <Button android:id="@+id/btn6" style="@style/DialerKey" android:text="6" android:tag="6"/>
        </LinearLayout>

        <!-- Row 3: 7 8 9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button android:id="@+id/btn7" style="@style/DialerKey" android:text="7" android:tag="7"/>
            <Button android:id="@+id/btn8" style="@style/DialerKey" android:text="8" android:tag="8"/>
            <Button android:id="@+id/btn9" style="@style/DialerKey" android:text="9" android:tag="9"/>
        </LinearLayout>

        <!-- Row 4: * 0 # -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button android:id="@+id/btnStar" style="@style/DialerKey" android:text="*" android:tag="*"/>
            <Button android:id="@+id/btn0"    style="@style/DialerKey" android:text="0" android:tag="0"/>
            <Button android:id="@+id/btnHash" style="@style/DialerKey" android:text="#" android:tag="#"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Call Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:gravity="center"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btnCall"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_call_btn"
            android:src="@android:drawable/ic_menu_call"
            android:tint="@color/white"
            android:padding="18dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp" />
    </LinearLayout>

</LinearLayout>
